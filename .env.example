# Root compose secrets — copy to `.env` (gitignored) for docker-compose.
#
# docker-compose passes these to BOTH the mqtt container (which seeds the
# privileged "backend" broker user) AND the backend container (which logs in
# with them). So this is the SINGLE place to set the broker password for a
# docker deploy — set it once here, no need to also edit backend/.env.
#
# If you don't create a .env, compose falls back to backend / hestiadev — fine
# for first-run dev, but CHANGE IT before exposing the broker (the backend user
# can read all telemetry and turn any stove on/off).
MQTT_USERNAME=backend
MQTT_PASSWORD=change-me-to-a-strong-password
