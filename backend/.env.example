# =========================
# Server
# =========================
NODE_ENV=development
# HOST is informational only — server.js binds 0.0.0.0.
HOST=0.0.0.0
# Port the API listens on. Any reverse proxy / tunnel (e.g. api.hestia.my)
# must forward to this port. Matches server.js default + the frontend default.
PORT=3001
API_PREFIX=/api

# =========================
# Frontend (CORS)
# =========================
# Comma-separated allowlist of browser origins allowed to call this API.
# Leave empty to reflect any origin (dev only). Production example:
#   FRONTEND_ORIGIN=https://hestia.my,https://www.hestia.my
FRONTEND_ORIGIN=http://localhost:5173

# =========================
# Supabase (DB + Auth)
# =========================
# SUPABASE_URL / SUPABASE_ANON_KEY can also be supplied as VITE_* (shared
# with the frontend build). SERVICE_ROLE key is backend-only — never expose it.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =========================
# MQTT (IoT / Sensors)
# =========================
# Local dev: mqtt://localhost:1883   |   Server: mqtt://YOUR_BROKER_IP:1883
# Empty/off = MQTT bridge disabled (API still runs).
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# =========================
# Push Notifications (Web Push)
# =========================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# =========================
# Camera stream (PRD section 13)
# =========================
# Shared secret used to mint MJPEG stream tokens. MUST equal the firmware's
# CAMERA_STREAM_SECRET. Leave blank to disable camera streaming (the token
# endpoint then returns 503).
CAMERA_STREAM_SECRET=
# Stream token lifetime in seconds (only gates connecting; the socket persists).
CAMERA_STREAM_TOKEN_TTL=120
