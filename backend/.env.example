# =========================
# Server
# =========================
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
API_PREFIX=/api

# =========================
# Frontend (CORS)
# =========================
FRONTEND_ORIGIN=http://localhost:5173

# =========================
# Supabase (DB + Auth)
# =========================
# SUPABASE_URL / SUPABASE_ANON_KEY can also be used as VITE_*
# if shared with frontend build system.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =========================
# MQTT (IoT / Sensors)
# =========================
# Local dev: mqtt://localhost:1883   |   Vultr server: mqtt://YOUR_VULTR_IP:1883
MQTT_BROKER_URL=#mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# =========================
# Push Notifications (Web Push)
# =========================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

