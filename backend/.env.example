# =========================
# Server
# =========================
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
API_PREFIX=/api

# =========================
# Frontend (CORS)
# =========================
FRONTEND_ORIGIN=http://localhost:5173

# =========================
# Supabase (DB + Auth)
# =========================
# SUPABASE_URL / SUPABASE_ANON_KEY can also be used as VITE_*
# if shared with frontend build system.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =========================
# MQTT (IoT / Sensors)
# =========================
# Local dev: mqtt://localhost:1883   |   Vultr server: mqtt://YOUR_VULTR_IP:1883
MQTT_BROKER_URL=#mqtt://localhost:1883
# The backend uses the privileged "backend" MQTT user (full access). Devices get
# their own per-device users via mqtt/provision-device.sh.
MQTT_USERNAME=backend
MQTT_PASSWORD=

# =========================
# Push Notifications (Web Push)
# =========================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# =========================
# Camera stream (PRD section 13)
# =========================
# Shared secret used to mint MJPEG stream tokens. MUST equal the firmware's
# CAMERA_STREAM_SECRET. Leave blank to disable camera streaming (the token
# endpoint then returns 503).
CAMERA_STREAM_SECRET=
# Stream token lifetime in seconds (only gates connecting; the socket persists).
CAMERA_STREAM_TOKEN_TTL=120

