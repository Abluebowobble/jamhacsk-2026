# ----------------------------------------------------------------------------
# Hestia backend environment.
# Copy this file to ".env" and fill in values:  cp .env.example .env
# ".env" is git-ignored; ".env.example" is committed as the template.
# ----------------------------------------------------------------------------

# --- Where THIS server listens -----------------------------------------------
# Localhost for development. For the Vultr server, set HOST=0.0.0.0 so it binds
# the public interface, and PORT to whatever the firewall/reverse-proxy expects.
NODE_ENV=development
HOST=127.0.0.1
PORT=3000

# Path prefix for all API routes (frontend calls e.g. /api/health).
API_PREFIX=/api

# --- CORS: who is allowed to call this server --------------------------------
# The frontend origin. Vite dev server defaults to http://localhost:5173.
# On Vultr, set this to your deployed frontend origin (comma-separate many).
FRONTEND_ORIGIN=http://localhost:5173

# --- Upstream / device backend (the thing we "fetch data from") --------------
# Local Raspberry Pi / device API during dev. Swap to the Vultr-hosted service
# (or the Pi's public address) in production by changing ONLY this line.
UPSTREAM_BASE_URL=http://127.0.0.1:8000
# Optional bearer token sent to the upstream backend. Leave blank if not needed.
UPSTREAM_API_KEY=

# Outbound request timeout (ms) when talking to the upstream backend.
UPSTREAM_TIMEOUT_MS=8000
