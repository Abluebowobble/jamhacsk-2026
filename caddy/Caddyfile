# Caddy reverse proxy for Hestia.
#
# Caddy listens on 80/443, automatically obtains + renews a free Let's Encrypt
# HTTPS certificate for api.hestia.my, and forwards traffic to the backend
# container (reachable as `backend:3000` on the compose network).
#
# Requirements for the certificate to issue:
#   - api.hestia.my must resolve to this server's public IP (Cloudflare A record).
#   - Ports 80 and 443 must be open to the internet (firewall: see DEPLOY.md).
{
	# ACME account email for cert expiry notices. Change to a real address.
	email admin@hestia.my
}

api.hestia.my {
	reverse_proxy backend:3000
}
