# Hestia Pi firmware config — copy to .env and fill in.

# Device identity. Both come from mqtt/provision-device.sh and must match the
# device's row in Supabase `devices`. They key the MQTT topic + ACL.
DEVICE_ID=
HOUSEHOLD_ID=

# MQTT broker URL. The backend must connect to the SAME broker.
# Local dev example: mqtt://localhost:1883
MQTT_BROKER_URL=mqtt://localhost:1883

# Broker password for THIS device (from provisioning). The username is the
# DEVICE_ID — set automatically, so there is no MQTT_USERNAME here.
MQTT_PASSWORD=

# Seconds between MQTT keepalive pings.
MQTT_KEEPALIVE=60

# =========================
# Presence detection (vision) — all optional, sensible defaults shown.
# =========================
# Min detector confidence (0..1) to count a person.
PRESENCE_CONFIDENCE=0.5
# Min fraction of the frame a person box must fill (filters far-away people/pets).
PRESENCE_MIN_BOX_AREA=0.02
# Region of interest as fractional x0,y0,x1,y1 (box centre must fall inside).
# Leave unset for the whole frame. Example for the lower-centre near the stove:
# PRESENCE_ROI=0.2,0.3,0.8,1.0
# Consecutive agreeing frames before a presence change is trusted (debounce).
PRESENCE_DEBOUNCE_FRAMES=3
# OpenCV VideoCapture index used only when picamera2 isn't available (dev).
PRESENCE_CAMERA_INDEX=0
PRESENCE_FRAME_WIDTH=640
PRESENCE_FRAME_HEIGHT=480
# Directory holding the MobileNet-SSD model files (default: firmware/models).
# PRESENCE_MODEL_DIR=
