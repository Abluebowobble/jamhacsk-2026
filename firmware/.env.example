# Hestia Pi firmware config — copy to .env and fill in.

# This device's UUID. (Verification is currently DISABLED for testing, so this
# is optional and need not match a Supabase `devices` row.)
DEVICE_ID=

# MQTT broker URL. The backend must connect to the SAME broker.
#   Local dev:    mqtt://localhost:1883
#   Vultr server: mqtt://YOUR_VULTR_IP:1883
MQTT_BROKER_URL=mqtt://localhost:1883

# Broker authentication. Defaults match the docker-compose broker (dev creds).
MQTT_USERNAME=
MQTT_PASSWORD=

# Seconds between MQTT keepalive pings.
MQTT_KEEPALIVE=60
