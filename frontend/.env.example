VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the Hestia backend (Fastify). Defaults to http://localhost:3001.
VITE_API_URL=http://localhost:3001

# Web Push (notifications settings). Public half of the backend's VAPID pair.
# Must match VAPID_PUBLIC_KEY in backend/.env. Without it the toggle stays
# disabled with an explanatory note.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
