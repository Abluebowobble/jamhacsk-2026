VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the Hestia backend (Fastify).
#   Local dev:   http://localhost:3001
#   Production:  https://api.hestia.my
# VITE_* vars are baked in at build time — rebuild/redeploy after changing,
# and set the same value in your host's env vars (e.g. Vercel).
VITE_API_URL=http://localhost:3001

# Web Push (notifications). Public half of the backend's VAPID pair.
# Must match VAPID_PUBLIC_KEY in backend/.env. Without it the toggle stays
# disabled with an explanatory note.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
