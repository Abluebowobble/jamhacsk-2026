VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the Hestia backend (Fastify).
#   Local dev:   http://localhost:3000
#   Production:  https://api.hestia.my   (Caddy reverse proxy on the Vultr server)
# An HTTPS frontend MUST call an HTTPS backend (no mixed content). VITE_* vars are
# baked in at build time — rebuild/redeploy after changing, and set the same value
# in your host's env vars (e.g. Vercel).
VITE_API_URL=https://api.hestia.my

# Web Push (notifications). Public half of the backend's VAPID pair.
# Must match VAPID_PUBLIC_KEY in backend/.env. Without it the toggle stays
# disabled with an explanatory note.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
